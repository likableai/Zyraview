# Copy to .env.local for local dev (never commit secrets)

# Zyrachain Express API (must match browser origin / CORS)
NEXT_PUBLIC_API_URL=http://localhost:4000
LOCAL_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_LOCAL_SERVER_URL=http://localhost:4000

# Optional: set these if you need to hit a remote backend while developing
# SERVER_URL=https://your-production-backend.example.com
# NEXT_PUBLIC_SERVER_URL=https://your-production-backend.example.com

# Override automatic local/remote detection (defaults to local in dev)
# FORCE_REMOTE_BACKEND=true
# NEXT_PUBLIC_FORCE_REMOTE_BACKEND=true
# FORCE_LOCAL_BACKEND=true
# NEXT_PUBLIC_FORCE_LOCAL_BACKEND=true
